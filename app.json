{
  "expo": {
    "name": "saferoute-yopal",
    "slug": "saferoute-yopal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.saferoute.yopal",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeRoute Yopal usa tu ubicación para alertarte de zonas de riesgo vial en tiempo real.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeRoute Yopal necesita acceso continuo al GPS para alertarte incluso con la app en segundo plano.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
  "package": "com.saferoute.yopal",
  "versionCode": 1,
  "adaptiveIcon": {
    "foregroundImage": "./assets/adaptive-icon.png",
    "backgroundColor": "#ffffff"
  },
  "edgeToEdgeEnabled": true,
  "config": {
    "googleMaps": {
      "apiKey": "TU_API_KEY_AQUI"
    }
  },
  "permissions": [
    "ACCESS_COARSE_LOCATION",
    "ACCESS_FINE_LOCATION",
    "ACCESS_BACKGROUND_LOCATION",
    "FOREGROUND_SERVICE",
    "FOREGROUND_SERVICE_LOCATION",
    "VIBRATE"
  ]
}
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SafeRoute Yopal necesita tu ubicación para alertarte de zonas de riesgo vial.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#cc0000"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "198ec74e-788b-4308-bf3a-c068337a3418"
      }
    }
  }
}
